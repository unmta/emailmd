{
  "name": "emailmd",
  "version": "0.1.5",
  "description": "Turn markdown into responsive, email-safe HTML that renders perfectly across every client.",
  "keywords": [
    "email",
    "markdown",
    "html-email",
    "email-template",
    "newsletter",
    "mjml",
    "cli"
  ],
  "license": "MIT",
  "author": "Dan Stevens",
  "homepage": "https://emailmd.dev",
  "repository": "github:unmta/emailmd",
  "bugs": "https://github.com/unmta/emailmd/issues",
  "bin": {
    "emailmd": "dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {
    "mjml": "mjml-browser"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "rm -f README.md LICENSE && cp ../../README.md ../../LICENSE .",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mjml": "^4.18.0",
    "mjml-browser": "^4.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/node": "^25.2.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
